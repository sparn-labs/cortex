{
  "name": "@sparn/cortex",
  "version": "2.0.1",
  "type": "module",
  "description": "Simple code scanning — security, compliance, and quality analysis for everyone",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cortex": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "PRIVACY.md"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "code-scanning",
    "security",
    "compliance",
    "quality",
    "owasp",
    "gdpr",
    "cli"
  ],
  "author": "sparn-labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sparn-labs/cortex.git"
  },
  "bugs": {
    "url": "https://github.com/sparn-labs/cortex/issues"
  },
  "homepage": "https://github.com/sparn-labs/cortex#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
